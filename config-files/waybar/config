{
    "position": "top",
    "modules-left": ["tray"],
    "modules-center": ["hyprland/workspaces"],
    "modules-right": ["pulseaudio", "network", "cpu", "memory", "temperature", "battery", "clock"],

    "hyprland/workspaces" : {
        "on-click": "activate",
        "active-only": false,
        "all-outputs": true,
        "format": "{}",
        "persistent-workspaces": {
            "*": 10
        }
    },
    "tray": {
        "icon-size": 16,
        "spacing": 5
    },
    "clock": {
        "format": "{:%H:%M - %d.%m.%Y}",
        "tooltip": false
    },
    "cpu": {
        "format": "ΎΜδ  {usage}%",
        "tooltip": false
    },
    "memory": {
        "format": "ΎΔΚ  {}%",
        "tooltip": false
    },
    "temperature": {
        "critical-threshold": 80,
        "format": "ΎΜΚ {temperatureC}┬░C",
        "tooltip": false
    },
    "battery": {
        "states": {
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "ΎΩπ {capacity}%",
        "format-plugged": "ΎΘο {capacity}%",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
    },
    "network": {
        "format-wifi": "ΎΘτ   {signalStrength}%",
        "format-ethernet": "ΎηΨ",
        "tooltip-format": "{ifname} - {essid} - {ipaddr}",
        "format-linked": "{ifname} (No IP)",
        "format-disconnected": "έγι Disconnected"
    },
    "pulseaudio": {
        "format": "{icon} {volume}% {format_source}",
        "format-bluetooth": "{volume}% {icon}ΎΛΦ {format_source}",
        "format-bluetooth-muted": "Ύγσ {icon}ΎΛΦ {format_source}",
        "format-muted": "Ύγσ {format_source}",
        "format-source": "ΎΕ░ {volume}%",
        "format-source-muted": "ΎΕ▒",
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "ΎΨΡ",
            "headset": "ΎΨΡ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        },
        "on-click": "pavucontrol",
        "tooltip": false
    }
}

