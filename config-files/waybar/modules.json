{
  "group/audio": {
    "orientation": "inherit",
    "modules": [
        "pulseaudio#output",
        "pulseaudio#input"
    ]
  },
  "group/power": {
    "orientation": "inherit",
    "drawer": {
        "click-to-reveal": true,
        "transition-duration": 500
    },
    "modules": [
        "custom/nixos",
        "custom/poweroff",
        "custom/reboot"
    ]
  },
  "group/tray": {
    "orientation": "inherit",
    "drawer": {
        "transition-duration": 500
    },
    "modules": [
        "custom/trayicon",
        "tray"
    ]
  },
  "group/hardware": {
    "orientation": "inherit",
    "modules": [
        "cpu",
        "memory",
        "disk"
    ]
  },
  "group/timedate": {
    "orientation": "inherit",
    "modules": [
        "clock#time",
        "clock#date"
    ]
  },

  "custom/nixos": {
    "format": "пЊ“ NixOS",
    "tooltip": false
  },
  "custom/poweroff": {
    "format": "вЏ»",
    "tooltip-format": "Shutdown",
    "on-double-click": "poweroff"
  },
  "custom/reboot": {
    "format": "у°‘“",
    "tooltip-format": "Reboot",
    "on-double-click": "reboot"
  },
  "custom/trayicon": {
    "format": "пђЋ",
    "tooltip": false
  },
  "tray": {
      "icon-size": 16,
      "spacing": 5
  },

  "hyprland/workspaces": {
      "on-click": "activate",
      "active-only": false,
      "all-outputs": true,
      "format": "{}",
      "persistent-workspaces": {
          "*": 10
      }
  },

  "pulseaudio#output": {
      "format": "пЂ§ {volume}%",
      "format-bluetooth": "пЉ”пЂ§ {volume}%",
      "format-bluetooth-muted": "пЉ”о»Ё mute",
      "format-muted": "о»Ё mute",
      "on-click": "pavucontrol",
      "tooltip": false
  },
  "pulseaudio#input": {
      "format": "{format_source}",
      "format-source": "п„° {volume}%",
      "format-source-muted": "п„±",
      "on-click": "pavucontrol",
      "tooltip": false
  },
  "network": {
    "format-wifi": "п‡«",
    "format-ethernet": "у°€Ђ",
    "format-disconnected": "о«ђ Disconnected",
    "tooltip-format-wifi": "{ifname} - {essid} ({signalStrength}%) - {ipaddr}",
    "tooltip-format-ethernet": "{ifname} - {ipaddr}",
    "tooltip-format-disconnected": "",
    "states": {
      "regular": 50,
      "medium": 35,
      "bad": 20
    },
    "interval": 5

  },
  "cpu": {
      "format": "п‹›",
      "tooltip-format": "LOAD: {avg_freqency}% - USAGE: {usage}",
      "states": {
        "critical": 90,
        "bad": 75,
        "medium": 60,
        "regular": 0
      },
      "interval": 2
  },
  "memory": {
      "format": "ої…",
      "tooltip-format": "mem: {percentage}% [{used:0.1f}/{total:0.1f}GiB]\nswap: {swapPercentage}% [{swapUsed:0.1f}/{swapTotal:0.1f}GiB]",
      "states": {
          "critical": 90,
          "bad": 75,
          "medium": 60,
          "regular": 0
      },
      "interval": 5
    },
  "disk": {
      "format": "о™Ќ",
      "unit": "GB",
      "tooltip-format": "Space left: {free} ({percentage_free}%)\nUsed {specific_used:0.1f}GB of {specific_total:0.1f}GB ({percentage_used}%)",
      "states": {
          "critical": 90,
          "bad": 80,
          "medium": 70,
          "regular": 0
      },
      "interval": 30
  },
  "temperature": {
      "critical-threshold": 80,
      "format": "п‹‰",
      "tooltip-format": "{temperatureC}В°C",
      "interval": 10
  },
  "battery": {
      "format": "{icon} {capacity}%",
      "format-charging": "п‡¦ {capacity}%",
      "format-icons": ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"],
      "states": {
        "regular": 100,
        "medium": 50,
        "bad": 30,
        "critical": 20
      },
      "interval": 3
  },
  "clock#time": {
      "format": "{:%H:%M:%S}",
      "tooltip": false,
      "interval": 1
  },
  "clock#date": {
      "format": "{:%d.%m.%Y}",
      "tooltip": false
  }
}